# ============ SmartVersa environment (Railway → Variables) ============

# ---- Flask ----
SECRET_KEY=change-me-to-a-long-random-string
SESSION_COOKIE_SECURE=true          # true on Railway (HTTPS); false for local http
SESSION_LIFETIME_HOURS=12

# ---- Admin login (replaces password-in-URL) ----
# Multiple admins supported: "user1:pass1,user2:pass2"
ADMIN_CREDENTIALS=admin:choose-a-strong-password
# (Legacy fallback, single admin "admin"): ADMIN_PASSWORD=

# ---- WhatsApp Cloud API (Meta) ----
VERIFY_TOKEN=smartversa_bot_2026
WHATSAPP_TOKEN=your-meta-whatsapp-token
PHONE_NUMBER_ID=1207113965816609
WHATSAPP_API_VERSION=v23.0
# Optional: enables X-Hub-Signature-256 verification of incoming webhooks
META_APP_SECRET=

# ---- Google Sheets ----
GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...paste full JSON...}
GOOGLE_SHEET_NAME=SmartVersa Leads
LEADS_WORKSHEET=Sheet1
MESSAGES_WORKSHEET=Messages
SHEETS_CACHE_TTL=20
ENSURE_HEADERS=true

# ---- Business ----
WEBSITE_URL=https://smartversa.in
PAYMENT_URL=https://pay.smartversa.in/orderform

# ---- AI Counsellor (optional; leave provider=none to run rule-based only) ----
AI_PROVIDER=none                    # openai | anthropic | none
AI_API_KEY=
AI_MODEL=                           # optional override
AI_MAX_TOKENS=600
AI_TIMEOUT=30

# ---- Ops ----
LOG_LEVEL=INFO
RATE_LIMIT_LOGIN=8
RATE_LIMIT_WINDOW=300
